DJANGO_ENV=development
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
SITE_URL=http://127.0.0.1:8000
FRONTEND_SITE_URL=http://127.0.0.1:5173
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Local development only. Production must use PostgreSQL.
SQLITE_NAME=%TEMP%\\eduflow-lms\\db.dev.sqlite3

# Production database. Use DATABASE_URL on Render or set the POSTGRES_* values.
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
POSTGRES_SSL_REQUIRE=True
POSTGRES_CONN_MAX_AGE=60

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Twilio WhatsApp configuration
# Example sandbox sender: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional: use a Twilio Content Template for production-approved WhatsApp notifications.
# If set, the OTP is passed as variable {{1}}.
TWILIO_WHATSAPP_CONTENT_SID=
